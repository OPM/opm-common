-- Minimal dummy case based on SPE1 (Odeh 1981) physics.
-- Purpose: test bed for LGR summary vector infrastructure (PR00 onwards).
--
-- Global grid: 3 x 3 x 1
--   +-------+-------+-------+
--   | (1,3) | (2,3) | (3,3) | <- LGR2 host: global cell (3,3,1)
--   +-------+-------+-------+
--   | (1,2) | (2,2) | (3,2) |    centre cell: no LGR
--   +-------+-------+-------+
--   | (1,1) | (2,1) | (3,1) | <- LGR1 host: global cell (1,1,1)
--   +-------+-------+-------+
--   (note: I increases right, J increases up)
--
-- LGR1: global cell (1,1,1) refined into 3x3x1 fine cells — INJ here
-- LGR2: global cell (3,3,1) refined into 3x3x1 fine cells — PROD here
--
--   Fine cell layout (same for both LGRs):
--     (1,3) (2,3) (3,3)
--     (1,2) (2,2) (3,2)  <- well at centre (2,2,1)
--     (1,1) (2,1) (3,1)
--
-- Wells:
--   INJ  - gas injector - LGR1 fine cell (2,2,1)
--   PROD - oil producer - LGR2 fine cell (2,2,1)
--
-- PR00 test coverage:
--   Fix 1: LW*/LC*/LB* all three second-letter branches exercised
--   Fix 2: lgr_ field populated and converted for both wells
--   Fix 3: serializeOp / operator== on lgr_info (unit tests)
--   Fix 4: LBPR requests 'LGR1' 2 2 1 AND 'LGR2' 2 2 1 — same keyword,
--           same ijk, different LGR name. Without lgr_ in Block operator==
--           one node is silently dropped. Also exercised for LW* and LC*
--           via same keyword spanning both LGRs in one keyword block.

---------------------------------------------------------------------------
------- 3x3x1 2LGR (INJ in LGR1, PROD in LGR2) — Fix 4 stress test -----------------
---------------------------------------------------------------------------

RUNSPEC
-- -----------------------------------------------------------------------

TITLE
   3x3x1 DUMMY - LGR1 at (1,1,1) INJ, LGR2 at (3,3,1) PROD

DIMENS
   3 3 1 /

EQLDIMS
/

TABDIMS
/

OIL
GAS
WATER
DISGAS

FIELD

START
   1 'JAN' 2015 /

WELLDIMS
-- MaxWells  MaxCompl  MaxGroups  MaxWellsInGroup
        2         1         1          2 /

UNIFOUT

GRID
-- -----------------------------------------------------------------------

-- LGR1: refine global cell (1,1,1) — injector side
CARFIN
-- NAME  I1 I2  J1 J2  K1 K2  NX  NY  NZ
'LGR1'   1  1   1  1   1  1   3   3   1 /
ENDFIN

-- LGR2: refine global cell (3,3,1) — producer side
CARFIN
-- NAME  I1 I2  J1 J2  K1 K2  NX  NY  NZ
'LGR2'   3  3   3  3   1  1   3   3   1 /
ENDFIN

INIT

DX
   9*1000 /

DY
   9*1000 /

DZ
   9*50 /

TOPS
   9*8325 /

PORO
   9*0.3 /

PERMX
   9*500 /

PERMY
   9*200 /

PERMZ
   9*200 /

ECHO

PROPS
-- -----------------------------------------------------------------------

