SOLUTION
-- -----------------------------------------------------------------------

RPTSOL
RESTART=1 SOIL SWAT SGAS /

EQUIL
-- Datum(ft)  P@datum(psia)  WOC(ft)  Pcow@WOC  GOC(ft)  Pcog@GOC  RSVD  RVVD  NRPVT
      8400       4800          8450      0         8300      0        1     0     0 /

RSVD
-- Depth(ft)  Rs(Mscf/stb)
   8300        1.270
   8450        1.270 /

SUMMARY
-- -----------------------------------------------------------------------

-- =========================================================
-- FIELD LEVEL
-- =========================================================
FOPR
FGOR
FWCT
FWIR

-- =========================================================
-- GLOBAL WELL LEVEL  (W*)
-- Both wells appear at global timesteps even though both live in LGRs.
-- Cross-check: W* must equal LW* for the same well.
-- =========================================================
WBHP
  'INJ'
  'PROD'
/
WOPR
  'INJ'
  'PROD'
/
WGIR
  'INJ'
  'PROD'
/
WGOR
  'PROD'
/
WWPR
  'INJ'
  'PROD'
/

-- =========================================================
-- GLOBAL BLOCK LEVEL  (B*)
-- LGR1 host (1,1,1) and LGR2 host (3,3,1) give coarse aggregates.
-- Centre cell (2,2,1) has no LGR — undisturbed reference value.
-- Cross-check: B* of host cell should be close to LB* of centre fine cell.
-- =========================================================
BPR
  1  1  1 /
  2  2  1 /
  3  3  1 /
/

BGSAT
  1  1  1 /
  2  2  1 /
  3  3  1 /
/

-- =========================================================
-- LGR WELL LEVEL  (LW*)
-- Syntax: LWkeyword / 'LGRName'  'WellName' / /
--
-- Fix 1: LW* exercises the 'W' branch inside case 'L' in category_from_keyword().
-- Fix 4 (Well): LWBHP and LWSTAT each carry two records — one per LGR.
--   If lgr_ is absent from operator==, nodes with the same well name in
--   two different LGRs would incorrectly deduplicate. Caught cleanly
--   by the unit test LGR_node_dedup_uses_lgr; exercised here at deck level.
-- =========================================================

-- BHP — same keyword, both LGRs in one block (primary Fix 4 / Well stress test)
LWBHP
  'LGR1'  'INJ' /
  'LGR2'  'PROD' /
/

-- Status — same pattern as LWBHP
LWSTAT
  'LGR1'  'INJ' /
  'LGR2'  'PROD' /
/

-- INJ-specific: gas injection quantities
LWGIR
  'LGR1'  'INJ' /
/
LWGIT
  'LGR1'  'INJ' /
/
LWVIR
  'LGR1'  'INJ' /
/
LWVIT
  'LGR1'  'INJ' /
/
-- Regression sentinel: must be zero for a pure gas injector
LWWIR
  'LGR1'  'INJ' /
/

-- PROD-specific: oil production quantities
LWOPR
  'LGR2'  'PROD' /
/
LWOPT
  'LGR2'  'PROD' /
/
LWWPR
  'LGR2'  'PROD' /
/
LWGOR
  'LGR2'  'PROD' /
/
LWVPR
  'LGR2'  'PROD' /
/

-- =========================================================
-- LGR CONNECTION LEVEL  (LC*)
-- Syntax: LCkeyword / 'LGRName'  'WellName'  I  J  K / /
-- INJ at LGR1(2,2,1);  PROD at LGR2(2,2,1).
--
-- Fix 1: LC* exercises the 'C' branch inside case 'L'.
-- Fix 4 (Connection): LCPR and LCGFR each span both LGRs.
--   namedEntity differs (INJ vs PROD) so the dedup bug is not triggered
--   directly, but the ordering chain through namedEntity → number → lgr_
--   is fully exercised.
-- =========================================================

-- Connection pressure — both wells, both LGRs
LCPR
  'LGR1'  'INJ'   2  2  1 /
  'LGR2'  'PROD'  2  2  1 /
/

-- Gas flow rate — both wells (INJ injects; PROD produces associated gas)
LCGFR
  'LGR1'  'INJ'   2  2  1 /
  'LGR2'  'PROD'  2  2  1 /
/

-- Oil flow rate — both wells (regression zero for INJ)
LCOFR
  'LGR1'  'INJ'   2  2  1 /
  'LGR2'  'PROD'  2  2  1 /
/

-- Water flow rate — both wells (regression zero for INJ)
LCWFR
  'LGR1'  'INJ'   2  2  1 /
  'LGR2'  'PROD'  2  2  1 /
/

-- =========================================================
-- LGR BLOCK LEVEL  (LB*)
-- Syntax: LBkeyword / 'LGRName'  I  J  K / /
--
-- Fix 1: LB* exercises the 'B' branch inside case 'L'.
-- Fix 4 (Block) — DIRECT TEST:
--   LBPR requests 'LGR1' 2 2 1  AND  'LGR2' 2 2 1.
--   Both nodes share keyword=LBPR and ijk=(2,2,1). The only difference
--   is the LGR name. Without lgr_ in Block operator==, number() is equal
--   and one node is silently dropped by uniq(). This is the clearest
--   possible deck-level trigger of the Fix 4 block dedup bug.
--   Same applies to LBGSAT, LBSOIL, LBWSAT at (2,2,1).
-- =========================================================

-- Block pressure: corners + centre for each LGR
-- Pressure gradient: higher near INJ (LGR1), lower near PROD (LGR2)
LBPR
  'LGR1'  1  1  1 /
  'LGR1'  2  2  1 /
  'LGR1'  3  3  1 /
  'LGR2'  1  1  1 /
  'LGR2'  2  2  1 /
  'LGR2'  3  3  1 /
/

-- Gas saturation: grows from LGR1(2,2,1) as gas is injected
LBGSAT
  'LGR1'  1  1  1 /
  'LGR1'  2  2  1 /
  'LGR1'  3  3  1 /
  'LGR2'  1  1  1 /
  'LGR2'  2  2  1 /
  'LGR2'  3  3  1 /
/

-- Oil saturation at well cells — Fix 4 block dedup: same ijk, different LGR
LBSOIL
  'LGR1'  2  2  1 /
  'LGR2'  2  2  1 /
/

-- Water saturation at well cells — same Fix 4 pattern
LBWSAT
  'LGR1'  2  2  1 /
  'LGR2'  2  2  1 /
/

SCHEDULE
-- -----------------------------------------------------------------------

RPTSCHED
   'PRES' 'SGAS' 'RS' 'WELLS' /

RPTRST
   'BASIC=1' /

DRSDT
 0 /

-- Both wells are in LGRs -> WELSPECL + COMPDATL for both
WELSPECL
-- WellName  Group  LGRName   I  J  RefDepth(ft)  Phase
   'INJ'    'G1'   'LGR1'    2  2   8335         'GAS' /
   'PROD'   'G1'   'LGR2'    2  2   8400         'OIL' /
/

COMPDATL
-- WellName  LGRName   I  J  K1 K2  Flag    Tmult  PI     WellRad(ft)
   'INJ'    'LGR1'     2  2  1  1  'OPEN'   1*     1*     0.5 /
   'PROD'   'LGR2'     2  2  1  1  'OPEN'   1*     1*     0.5 /
/

WCONPROD
-- WellName  Flag   Control  OilRate(stb/d)  ...  BHPmin(psia)
   'PROD'   'OPEN' 'ORAT'    20000           4*    1000 /
/

WCONINJE
-- WellName  Phase  Flag    Control  Rate(Mscf/d)  1*  BHPmax(psia)
   'INJ'    'GAS' 'OPEN'  'RATE'    100000         1*   9014 /
/

TSTEP
-- 12 monthly steps (Jan-Dec 2015)
   31 28 31 30 31 30 31 31 30 31 30 31 /

END
